.godot/
bin/
obj/
/android/
.git/
.idea/
.vs/
publish/
Properties/
packages/
.editorconfig
*.user

# Local machine-specific config (game paths, Godot path). Never commit.
Directory.Build.props
local.props

# Build / export artifacts and generated game references (never commit game DLLs).
*.pck
*.pdb

# Excel lock files
~$*
sts2.dll
0Harmony.dll

# Logs and temporary export files.
*.log
logs/
*.tmp
/image-*.png.import
/tmp/*.png.import
/temp/pub*.txt
/temp/release/
/temp/release-staging/

# --- Distributable mod package ---
# Committed on purpose so anyone who clones/downloads the repo gets a ready-to-use
# mod (DLL + JSON + PCK with all textures). Overrides the broad *.pck / *.pdb rules above.
!dist/
!dist/**
